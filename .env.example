# Copia este archivo a .env y completa los valores

# API Key de Google AI Studio (Gemini)
# Obtén la tuya en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Directorio de persistencia de ChromaDB (opcional, por defecto: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# Credenciales para acceder a la gestión de documentos
DOCS_USER=admin
DOCS_PASSWORD=admin
